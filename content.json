rson.name);//undefined 注意：直接用delete删除不了变量123var name=&quot;李四&quot;delete name;console.log(name);//李四 删除不了原型链中的变量1234567function fun() &#123; this.name = &apos;mm&apos;;&#125;var obj = new fun();fun.prototype.age = 18;delete obj.age;console.log(obj.age) //18","categories":[],"tags":[]},{"title":"js正则分组反向引用","slug":"regular-backreferences","date":"2017-12-22T01:15:45.000Z","updated":"2017-12-22T01:34:12.451Z","comments":true,"path":"2017/12/22/regular-backreferences/","link":"","permalink":"http://yoursite.com/2017/12/22/regular-backreferences/","excerpt":"","text":"12var reg=/(\\d&#123;4&#125;)-(\\d&#123;2&#125;)-(\\d&#123;2&#125;)/g;&quot;2017-12-22&quot;.replace(reg,&apos;$2-$3-$1&apos;)","categories":[],"tags":[]},{"title":"利用filter实现数组去重","slug":"利用filter实现数组去重","date":"2017-12-20T05:33:49.000Z","updated":"2017-12-20T06:04:16.983Z","comments":true,"path":"2017/12/20/利用filter实现数组去重/","link":"","permalink":"http://yoursite.com/2017/12/20/利用filter实现数组去重/","excerpt":"","text":"12345var arr=[1,2,2,3,3,4,1,5];var newArr=arr.filter((item,index,array)=&gt;&#123; return index==array.indexOf(item) &#125;)console.log(newArr);//[1,2,3,4,5]","categories":[],"tags":[]},{"title":"正则表达式1-定义正则","slug":"正则表达式1-定义正则","date":"2017-12-20T01:06:10.000Z","updated":"2017-12-20T01:29:37.152Z","comments":true,"path":"2017/12/20/正则表达式1-定义正则/","link":"","permalink":"http://yoursite.com/2017/12/20/正则表达式1-定义正则/","excerpt":"","text":"定义正则表达式有两种方法 字面量方式，注意加/ / 12var reg=/\\bis\\b/g;&quot;This is LILI, he is 18&quot;.replace(reg,&quot;0&quot;) Regexp构造函数 1var reg2=new Regexp(&apos;\\bis\\b&apos;,&apos;g&apos;)","categories":[],"tags":[]},{"title":"webwuyou博客迁移啦","slug":"webwuyou博客迁移啦","date":"2017-12-19T03:17:59.000Z","updated":"2017-12-19T04:54:28.946Z","comments":true,"path":"2017/12/19/webwuyou博客迁移啦/","link":"","permalink":"http://yoursite.com/2017/12/19/webwuyou博客迁移啦/","excerpt":"","text":"博客正式迁移到github pages上了个人博客：前端无忧网主要是前端技术分享 前端无忧网(http://www.webwuyou.com) github主页(https://webwuyou.github.io)12http://www.webwuyou.comhttps://webwuyou.github.io","categories":[],"tags":[]},{"title":"测试文章","slug":"测试文章","date":"2017-12-19T02:28:29.000Z","updated":"2017-12-19T03:15:11.053Z","comments":true,"path":"2017/12/19/测试文章/","link":"","permalink":"http://yoursite.com/2017/12/19/测试文章/","excerpt":"","text":"测试文章Quick StartCreate a new post1$ hexo new \"My New Post\" More info: Writing Run server","categories":[],"tags":[]},{"title":"postName","slug":"postName","date":"2017-12-19T02:04:42.000Z","updated":"2017-12-19T02:04:42.964Z","comments":true,"path":"2017/12/19/postName/","link":"","permalink":"http://yoursite.com/2017/12/19/postName/","excerpt":"","text":"","categories":[],"tags":[]},{"title":"my new post","slug":"my-new-post","date":"2017-06-29T09:48:01.000Z","updated":"2017-06-29T10:03:47.392Z","comments":true,"path":"2017/06/29/my-new-post/","link":"","permalink":"http://yoursite.com/2017/06/29/my-new-post/","excerpt":"","text":"这是第一篇文章","categories":[],"tags":[]},{"title":"Hello World","slug":"hello-world","date":"2017-06-29T05:47:15.154Z","updated":"2017-06-29T05:47:15.154Z","comments":true,"path":"2017/06/29/hello-world/","link":"","permalink":"http://yoursite.com/2017/06/29/hello-world/","excerpt":"","text":"Welcome to Hexo! This is your very first post. Check documentation for more info. If you get any problems when using Hexo, you can find the answer in troubleshooting or you can ask me on GitHub. Quick StartCreate a new post1$ hexo new \"My New Post\" More info: Writing Run server1$ hexo server More info: Server Generate static files1$ hexo generate More info: Generating Deploy to remote sites1$ hexo deploy More info: Deployment","categories":[],"tags":[]}]}